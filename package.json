{
  "name": "oh-my-ralph",
  "version": "0.1.0",
  "description": "Meta CLI for running ralph persistence loops across coding agents",
  "type": "module",
  "bin": {
    "omr": "./dist/cli/index.js"
  },
  "scripts": {
    "build": "bun build src/cli/index.ts --outdir dist/cli --target node",
    "dev": "bun run src/cli/index.ts",
    "test": "bun test",
    "lint": "bunx @biomejs/biome check src/ tests/",
    "format": "bunx @biomejs/biome format --write src/ tests/"
  },
  "dependencies": {
    "commander": "^13.0.0",
    "yaml": "^2.7.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.0",
    "@types/bun": "latest"
  },
  "license": "MIT"
}
